// Personal Finance OS — core money loop schema
// Provider: PostgreSQL (Supabase). Prisma 7 `prisma-client` generator.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum IncomeType {
  SALARY
  BONUS
  FREELANCE
  INTEREST
  OTHER
}

enum ExpenseCategory {
  FOOD
  TRAVEL
  SMOKING
  SHOPPING
  ENTERTAINMENT
  MEDICAL
  UTILITIES
  BILLS
  INVESTMENTS
  EDUCATION
  GIFTS
  MISCELLANEOUS
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NETBANKING
  OTHER
}

enum AccountType {
  SAVINGS
  WALLET
  UPI
  EMERGENCY
}

enum InvestmentType {
  SIP
  MUTUAL_FUND
  STOCK
  GOLD
  FD
}

enum RecurringKind {
  INCOME
  EXPENSE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  monthlySalary Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  incomes     Income[]
  expenses    Expense[]
  budgets     Budget[]
  goals       Goal[]
  accounts    Account[]
  investments Investment[]
  recurring   RecurringTransaction[]
}

model Income {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String
  amount    Decimal    @db.Decimal(12, 2)
  type      IncomeType @default(SALARY)
  recurring Boolean    @default(false)
  date      DateTime   @default(now())
  note      String?
  createdAt DateTime   @default(now())

  @@index([userId, date])
}

model Expense {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal         @db.Decimal(12, 2)
  category      ExpenseCategory
  date          DateTime        @default(now())
  description   String?
  paymentMethod PaymentMethod   @default(UPI)
  notes         String?
  tags          String[]        @default([])
  createdAt     DateTime        @default(now())

  @@index([userId, date])
  @@index([userId, category])
}

// One row per category. Amount is the MONTHLY allocation for that category;
// daily and weekly targets are derived from it.
model Budget {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  ExpenseCategory
  amount    Decimal         @db.Decimal(12, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, category])
}

model Goal {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  icon                String    @default("target")
  targetAmount        Decimal   @db.Decimal(12, 2)
  savedAmount         Decimal   @default(0) @db.Decimal(12, 2)
  monthlyContribution Decimal   @default(0) @db.Decimal(12, 2)
  deadline            DateTime?
  completed           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      AccountType @default(SAVINGS)
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

// Templates that auto-generate an Income or Expense each month. Materialized
// lazily on app load once the day-of-month has arrived (see applyDueRecurring).
model RecurringTransaction {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          RecurringKind
  label         String
  amount        Decimal          @db.Decimal(12, 2)
  dayOfMonth    Int              @default(1)
  active        Boolean          @default(true)
  // Expense-only
  category      ExpenseCategory?
  paymentMethod PaymentMethod    @default(UPI)
  // Income-only
  incomeType    IncomeType?
  // Last month this template was materialized (idempotency guard)
  lastRunYear   Int?
  lastRunMonth  Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
}

model Investment {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         InvestmentType @default(SIP)
  invested     Decimal        @db.Decimal(12, 2)
  currentValue Decimal        @db.Decimal(12, 2)
  monthlySip   Decimal        @default(0) @db.Decimal(12, 2)
  date         DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
}
